# 사장님이 채워주실 환경변수. .env.local 로 복사 후 값 입력.
# Vercel 배포 시 vercel dashboard 의 Environment Variables 에도 같은 값 등록.

# ── Supabase ────────────────────────────────────────────────────────────
# Supabase 프로젝트 만들고 Settings → API 에서 가져옴.
# anon key 는 클라이언트에 노출돼도 OK (Row Level Security 로 보호).
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# ── 입금 계좌 (매출 전용 토스뱅크) ──────────────────────────────────────
# 사장님 매출 전용 계좌. 결제 페이지에 표시되는 값.
NEXT_PUBLIC_BANK_NAME=토스뱅크
NEXT_PUBLIC_BANK_ACCOUNT=1000-0000-0000
NEXT_PUBLIC_BANK_HOLDER=사장님이름

# ── 아이디어/제품 메타 (직원이 자동 채움 또는 수동) ──────────────────────
NEXT_PUBLIC_IDEA_NAME=AI 자기소개서 첨삭
NEXT_PUBLIC_IDEA_TAGLINE=30초만에 핵심 약점 + 개선안
NEXT_PUBLIC_IDEA_VALUE_PROP=취준생 100명이 검증한 첨삭 패턴을 즉시 적용
NEXT_PUBLIC_TARGET_AUDIENCE=취업 준비 중인 20대

# ── 사전예약 가격 정책 ──────────────────────────────────────────────────
NEXT_PUBLIC_PREORDER_PRICE=4900
NEXT_PUBLIC_REGULAR_PRICE=19900
NEXT_PUBLIC_EARLYBIRD_QUOTA=100
NEXT_PUBLIC_EARLYBIRD_BENEFIT=첫 3개월 무료 + 평생 50% 할인
NEXT_PUBLIC_REFUND_POLICY=출시 안 되면 100% 환불

# ── 캠페인 트래킹 (직원이 launch 시 자동 채움) ──────────────────────────
NEXT_PUBLIC_CAMPAIGN_ID=ca_unset
NEXT_PUBLIC_PROJECT_KEY=alpha-agent-ai

# ── 접속률·전환 추적 (PostHog) ──────────────────────────────────────────
# PostHog 계정은 기존 거 재사용 OK. 단, 이 랜딩용 "새 프로젝트"를 만들고
# Project Settings → Project API Key 를 여기 넣어야 데이터가 안 섞임.
# 키 없으면 추적만 꺼지고 사이트는 정상 작동 (no-op).
# 리전: 미국 us / 유럽 eu — PostHog 프로젝트 만들 때 고른 리전에 맞춰 HOST 변경.
NEXT_PUBLIC_POSTHOG_KEY=phc_여기에_새_프로젝트_키
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Vercel Web Analytics 는 키 불필요 — Vercel 배포 프로젝트에 자동 연결됨.
